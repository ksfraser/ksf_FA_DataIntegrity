{
    "name": "ksfraser/ksf_fa_dataintegrity",
    "description": "FrontAccounting Data Integrity Checker — finds orphaned GRNs, invoice/GRN quantity mismatches, allocation drift, and broken purchase/sales chains",
    "type": "library",
    "license": "GPL-3.0-or-later",
    "authors": [
        {
            "name": "KSFraser",
            "email": "dev@ksfraser.com"
        }
    ],
    "require": {
        "php": ">=7.3",
        "ksfraser/fa-classes": "^1.0",
        "ksfraser/ksf-modules-dao": "^0.4"
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/ksfraser/fa_classes.git"
        },
        {
            "type": "vcs",
            "url": "https://github.com/ksfraser/ksf_ModulesDAO.git"
        },
        {
            "type": "vcs",
            "url": "https://github.com/ksfraser/Validation.git"
        }
    ],
    "require-dev": {
        "phpunit/phpunit": "^10",
        "ksfraser/famock": "*"
    },
    "autoload": {
        "psr-4": {
            "Ksfraser\\FA\\DataIntegrity\\": "src/Ksfraser/FA/DataIntegrity/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ksfraser\\FA\\DataIntegrity\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
