{
    "name": "ksfraser/ksf_fa_dataintegrity",
    "description": "FrontAccounting Data Integrity Checker — finds orphaned GRNs, invoice/GRN quantity mismatches, allocation drift, and broken purchase/sales chains",
    "type": "library",
    "license": "GPL-3.0-or-later",
    "authors": [
        {
            "name": "KSFraser",
            "email": "dev@ksfraser.com"
        }
    ],
    "require": {
        "php": ">=7.3",
        "ksfraser/fa-classes": "dev-main"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../ksf_FA_Classes",
            "options": {
                "symlink": false,
                "versions": {
                    "ksfraser/fa-classes": "dev-main"
                }
            }
        },
        {
            "type": "path",
            "url": "../ksf_ModulesDAO",
            "options": {
                "symlink": false,
                "versions": {
                    "ksfraser/ksf-modules-dao": "dev-main"
                }
            }
        },
        {
            "type": "path",
            "url": "../validation",
            "options": {
                "symlink": false,
                "versions": {
                    "ksfraser/validation": "dev-main"
                }
            }
        }
    ],
    "require-dev": {
        "phpunit/phpunit": "^10",
        "ksfraser/famock": "*"
    },
    "autoload": {
        "psr-4": {
            "Ksfraser\\FA\\DataIntegrity\\": "src/Ksfraser/FA/DataIntegrity/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ksfraser\\FA\\DataIntegrity\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
